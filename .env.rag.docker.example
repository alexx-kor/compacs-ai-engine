# Docker stand — copy to .env.rag before: docker compose -f rag-compose.yml up -d

STORAGE_BACKEND=json
LOCAL_VECTOR_STORE_DIR=/app/data/vectors
INSTRUCTIONS_DIR=/app/instructions

LLM_PROVIDER=ollama
LLM_FALLBACK_ENABLED=false
EMBEDDING_PROVIDER=ollama
EMBEDDING_FALLBACK_ENABLED=false

OLLAMA_HOST=http://ollama:11434
OLLAMA_MODEL=llama3.2:3b
EMBED_MODEL=nomic-embed-text
# Keep model loaded between requests (avoid ~50s cold load per query)
OLLAMA_KEEP_ALIVE=30m
OLLAMA_CLIENT_TIMEOUT=300
NUM_CTX=8192
NUM_PREDICT=400

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
MAX_TOKENS=600

CHUNK_SIZE=1000
CHUNK_OVERLAP=150
TOP_K=12
# 3 chunks × ~350 chars keeps prefill fast on llama3.2:3b
RERANK_TOP_K=3
OLLAMA_CONTEXT_CHUNKS=3
OLLAMA_CHUNK_CHARS=350
SIMILARITY_THRESHOLD=0.35
CACHE_ENABLED=true
CACHE_TTL=3600

COMPACS_API_KEY=compacs-local-dev-key
COMPACS_MODELS=compacs-rag
COMPACS_PRO_KEY=

# Compose without ollama container: rag-compose.host-ollama.yml
# OLLAMA_HOST stays http://host.docker.internal:11434 (set in compose file)
# Windows: run scripts/setup-ollama-docker-windows.ps1 so Docker can call /api/chat

RAG_GATEWAY_PORT=3090
