# Docker stand — copy to .env.rag before: docker compose -f rag-compose.yml up -d

STORAGE_BACKEND=json
LOCAL_VECTOR_STORE_DIR=/app/data/vectors
INSTRUCTIONS_DIR=/app/instructions

LLM_PROVIDER=ollama
LLM_FALLBACK_ENABLED=false
EMBEDDING_PROVIDER=ollama
EMBEDDING_FALLBACK_ENABLED=false

OLLAMA_HOST=http://ollama:11434
OLLAMA_MODEL=llama3.2:3b
EMBED_MODEL=nomic-embed-text

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

CHUNK_SIZE=1000
CHUNK_OVERLAP=150
TOP_K=12
RERANK_TOP_K=5
SIMILARITY_THRESHOLD=0.35
CACHE_ENABLED=true
CACHE_TTL=3600

COMPACS_API_KEY=compacs-local-dev-key
COMPACS_MODELS=compacs-rag
COMPACS_PRO_KEY=

RAG_GATEWAY_PORT=3080
GATEWAY_WORKERS=4
GATEWAY_TIMEOUT=120
