# RAG runtime — copy to .env.rag (never commit real secrets)

STORAGE_BACKEND=auto
LOCAL_VECTOR_STORE_DIR=data/vectors
INSTRUCTIONS_DIR=instructions

LLM_PROVIDER=auto
LLM_FALLBACK_ENABLED=true
EMBEDDING_PROVIDER=auto
EMBEDDING_FALLBACK_ENABLED=true

OPENAI_API_KEY=

OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
MAX_TOKENS=1000
OPENAI_MAX_REQUESTS_PER_MIN=60
OPENAI_DAILY_BUDGET_USD=10.0

OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2:3b
EMBED_MODEL=nomic-embed-text
OLLAMA_EMBED_MAX_CHARS=1800

CHUNK_SIZE=1000
CHUNK_OVERLAP=150
TOP_K=12
RERANK_TOP_K=5
SIMILARITY_THRESHOLD=0.35
CACHE_ENABLED=true
CACHE_TTL=3600

# Multi-strategy chunking (section helps retrieval on numbered docs)
CHUNK_STRATEGIES=sliding,section,graph,qa,definition

# LibreChat / OpenAI-compatible API (must match COMPACS_API_KEY in .env)
COMPACS_API_KEY=compacs-local-dev-key
COMPACS_MODELS=compacs-rag

# Hybrid retrieval (dense + BM25 sidecar bm25_index.json)
HYBRID_SEARCH_ENABLED=true
HYBRID_DENSE_WEIGHT=0.65
HYBRID_BM25_WEIGHT=0.35
BM25_LEMMATIZE=true
RERANK_LEMMATIZE=true
