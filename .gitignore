instructions/graph/**
!instructions/graph/.gitkeep
instructions/golden/**
!instructions/golden/.gitkeep
instructions/few_shot/**
!instructions/few_shot/.gitkeep
instructions/*.extract.txt
instructions/**/*.extract.txt

# Python cache/bytecode
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
.venv/
venv/
env/
ENV/

