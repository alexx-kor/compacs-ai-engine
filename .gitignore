# User documents (do not commit proprietary corpora)
instructions/**/*.txt
instructions/**/*.pdf
instructions/**/*.md
instructions/**/*.rst
instructions/**/*.extract.txt

# Keep directory structure in git
!instructions/raw/.gitkeep
!instructions/graph/.gitkeep
!instructions/golden/.gitkeep
!instructions/few_shot/.gitkeep

# Python cache/bytecode
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
.venv/
venv/
env/
ENV/

# Packaging/build artifacts
build/
dist/
*.egg-info/
.eggs/
pip-wheel-metadata/

# Test/coverage
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.mypy_cache/
.ruff_cache/

# Environment/local config
.env
.env.*
!.env.*.example

# Generated data and RAG artifacts
data/

# JSON vector store temp files (atomic write)
*.json.tmp

# Jupyter
.ipynb_checkpoints/

# IDE/editor
.idea/
.vscode/
*.swp
*.swo

# OS files
.DS_Store
Thumbs.db
desktop.ini

